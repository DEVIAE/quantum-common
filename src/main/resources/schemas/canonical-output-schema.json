                "severance": null,
                "social_security": null,
                "family_allowance": null,
                "family_allowance_simple": null
            }
        },
        {
            "_meta": {
                "record_id": "afc~AFC_076354771K_202502_01.DAT~00000001",
                "schema_version": "1.0",
                "institution": "AFC",
                "format_code": "afc",
                "period": "2025-02",
                "source_file": "AFC_076354771K_202502_01.DAT",
                "normalized_at": "2026-03-11T21:00:00Z",
                "normalizer_version": "1.0.0"
            },
            "worker": {
                "rut": "9000001",
                "dv": "5",
                "last_name_1": "PEREZ",
                "first_name": "JUAN",
                "taxable_income": 550000,
                "days_worked": 30
            },
            "contributions": {
                "afp": null,
                "sis": null,
                "apv": null,
                "afc_worker": 2750,
                "afc_employer": 5500,
                "afc_total": 8250,
                "health_fonasa": null,
                "health_isapre_agreed": null,
                "health_isapre_total": null,
                "accident": null,
